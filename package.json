{
  "name": "redflags",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build": "expo export",
    "build:ios": "npx eas-cli build --platform ios --profile production",
    "build:ios:local": "npx eas-cli build --platform ios --local --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --profile production",
    "build:submit": "npx eas-cli build --platform ios --profile production --auto-submit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/html-elements": "latest",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-voice/voice": "^3.2.4",
    "expo": "~51.0.0",
    "expo-apple-authentication": "~6.4.2",
    "expo-auth-session": "~5.5.2",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-device": "~6.0.2",
    "expo-image-picker": "~15.0.7",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.0",
    "expo-status-bar": "~1.12.1",
    "firebase": "^12.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-reanimated": "~3.10.0",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.79",
    "@types/react-native": "^0.72.2",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "typescript": "~5.3.3"
  },
  "private": true
}
